export interface SupplierFactory {
  name: string;
  country: string;
  ownership: string;
  otd: number;
  workers: number;
  machines: number;
  leadTime: string;
  annualOutput: string;
  firstPassRate: string;
  defectRate: string;
  thirdPartyQA: string;
  auditScore: string;
  certifications: string[];
  catalog: Array<{ name: string; desc: string; price: string; moq: string }>;
}

export interface Supplier {
  id: string;
  name: string;
  country: string;
  city: string;
  lat: number;
  lng: number;
  address: string;
  products: string[];
  productionCapacity: string;
  annualSpend: string;
  certificates: string[];
  riskLevel: 'Low' | 'Medium' | 'High' | 'Critical';
  contactName: string;
  contactEmail: string;
  established: string;
  employees: string;
  // Profile data
  purchaseVolume: string;
  radarActual: { qual: number; otd: number; lf: number; ta: number; comp: number; cert: number; lt: number };
  radarNorm: { qual: number; otd: number; lf: number; ta: number; comp: number; cert: number; lt: number };
  certCoverage: { gots: number; iso: number; bsci: number; smeta: number };
  kpiScores: { qualityIndex: number; qualityNorm: number; otdScore: number; otdNorm: number; taAvg: number; taNorm: number; lfAvg: number; lfNorm: number };
  incidentHistory: Array<{ year: string; safety: number; chemical: number; labor: number }>;
  incidentCauses: Array<{ name: string; value: number }>;
  factoryMatrix: { taScore: number; lfScore: number; compliance: string; higgScore: number; claimRatio: string };
  factories: SupplierFactory[];
}

